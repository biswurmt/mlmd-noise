# ── LLM Provider ────────────────────────────────────────────────────────────
# "nebius" → Nebius AI Studio (OpenAI-compatible, API key auth)
# "azure"  → Azure OpenAI (AzureCliCredential, requires az login)
LLM_PROVIDER=nebius

# ── Nebius AI Studio (used when LLM_PROVIDER=nebius) ────────────────────────
NEBIUS_API_KEY=
# Model to use for rule generation / verification.  Options:
#   meta-llama/Meta-Llama-3.1-8B-Instruct         (small, fast — good with RAG grounding)
#   mistralai/Mistral-7B-Instruct-v0.3            (small, fast — alternative to 8B)
#   meta-llama/Meta-Llama-3.1-70B-Instruct-fast  (larger, stronger reasoning)
#   meta-llama/Meta-Llama-3.1-405B-Instruct       (most capable)
#   Qwen/Qwen2.5-72B-Instruct                     (strong structured JSON)
#   deepseek-ai/DeepSeek-V3                       (strong code/structured)
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Azure OpenAI (used when LLM_PROVIDER=azure) ─────────────────────────────
ENDPOINT_URL=
DEPLOYMENT_NAME=
# NOTE: AzureCliCredential requires an active "az login" session.
# On Nebius VMs use API key auth instead (update kg_service.py accordingly).

# ── External medical APIs ────────────────────────────────────────────────────
UMLS_API_KEY=
INFOWAY_CLIENT_ID=
INFOWAY_CLIENT_SECRET=
BING_SEARCH_KEY=

# ── Neo4j (used when USE_NEO4J=true) ────────────────────────────────────────
# In docker-compose the service name "neo4j" resolves to the container.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong_password

# ── Knowledge graph PKL selection ────────────────────────────────────────────
# Options: triage_knowledge_graph_enriched.pkl (default) | triage_knowledge_graph.pkl
KG_PKL_FILE=triage_knowledge_graph_enriched.pkl

# ── Qdrant Cloud (vector DB for guidelines RAG) ──────────────────────────────
# Create a free cluster at https://cloud.qdrant.io → copy URL + API key here.
QDRANT_URL=https://<your-cluster-id>.aws.cloud.qdrant.io
QDRANT_API_KEY=
# Embedding model used by build_vector_db.py (default: intfloat/e5-mistral-7b-instruct)
NEBIUS_EMBEDDING_MODEL=intfloat/e5-mistral-7b-instruct

# ── Nebius S3 Object Storage ─────────────────────────────────────────────────
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=diagnotix-kg
# S3_REGION=eu-north1   # default, only override if using a different region
