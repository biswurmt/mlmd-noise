marimo/_static/
marimo/_lsp/
__marimo__/

# ── Project-specific ──────────────────────────────────────────────────────────

# Vector DB indexing checkpoint — tracks resume position, auto-deleted on completion
knowledge-graphs/vector_db/.index_checkpoint.json

# ChromaDB local store — binary index files, auto-regenerated via build_vector_db_chroma.py
knowledge-graphs/vector_db/chroma_db/
*.bin
*.sqlite3

# ClinGraph data — large CSV files downloaded from Harvard Dataverse, auto-excluded by *.csv
knowledge-graphs/clingraph_data/

# KG pipeline data — inputs/outputs stored locally, auto-excluded
knowledge-graphs/data/

# Secrets — never commit API keys or OAuth credentials
knowledge-graphs/.env
data-processing/.env

# Pickle files — binary, auto-regenerated, never commit
*.pkl
!knowledge-graphs/triage_knowledge_graph_enriched.pkl

# Generated graph artefacts
knowledge-graphs/*.html

# Data JSON files — pipeline inputs/outputs and checkpoints.
# Scoped to data directories to avoid catching frontend config
# files (package.json, tsconfig.json, etc.).
knowledge-graphs/*.json
data-processing/*.json

# Tabular data files — patient CSVs and pipeline output spreadsheets
*.csv
*.tsv
*.parquet
*.xlsx
*.xls
!data-processing/student_data_enriched_validation.csv
!data-processing/student_data_enriched_graphonly_validation.csv
!data-processing/student_data_enriched_graphonly_full_validation.csv


